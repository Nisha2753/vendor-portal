{
  "welcomeFile": "/index.html",
  "routes": [
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "service": "sapui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "service": "sapui5"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "localDir": "."
    }
  ]
}
