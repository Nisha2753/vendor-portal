<mvc:View
  controllerName="vendorportal.controller.Main"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m">

  <App id="mainApp">
   
   <Page id="loginPage" showHeader="false" enableScrolling="false">
  <content>
    <VBox class="loginBg" alignItems="Center" justifyContent="Center">

      <VBox class="loginCard">
        <Text text="⬡ Orane" class="loginLogo"/>
        <Title text="Vendor Portal Login" class="loginTitle"/>
        <Text text="Secure access for vendor onboarding and SAP OData services." class="loginSub"/>

        <Input id="loginEmail" placeholder="Email ID" value="nishsingh61746@gmail.com" class="formInput"/>
        <Input id="loginPassword" placeholder="Password" type="Password" class="formInput"/>

        <Button text="Login to Portal" type="Emphasized" press="onLogin" class="fullBtn"/>

        <Text text="Authorized user: nishsingh61746@gmail.com" class="loginHint"/>
      </VBox>

    </VBox>
  </content>
</Page>

    <!-- HOME PAGE -->
    <Page id="homePage" showHeader="false" enableScrolling="true">
      <content>
        <VBox class="shellBg">
          <VBox class="heroBox">

            <HBox class="brandBar" justifyContent="SpaceBetween" alignItems="Center">
              <Text text="⬡ Orane" class="brandLogo"/>
              <Text text="● SAP BTP Connected" class="statusPill"/>
            </HBox>

            <HBox class="heroGrid">
              <VBox class="heroLeft">
                <Text text="Vendor Intelligence Platform" class="badge"/>
                <Title text="Smarter Vendor" class="heroTitle"/>
                <Title text="Onboarding" class="heroTitle gradientText"/>
                <Title text="for SAP Teams" class="heroTitle"/>

                <Text
                  text="A premium SAP BTP vendor portal with onboarding score, AI assistant, voice input, and OData-ready vendor master display."
                  class="heroSub"/>

                <HBox class="metricRow">
                  <VBox class="metricCard">
                    <Text text="AI" class="metricNum"/>
                    <Text text="Scoring" class="metricLabel"/>
                  </VBox>

                  <VBox class="metricCard">
                    <Text text="OData" class="metricNum"/>
                    <Text text="Integration" class="metricLabel"/>
                  </VBox>

                  <VBox class="metricCard">
                    <Text text="UI5" class="metricNum"/>
                    <Text text="Fiori App" class="metricLabel"/>
                  </VBox>
                </HBox>
              </VBox>

              <VBox class="heroRight glassPanel">

                <VBox class="actionCard">
                  <Text text="📋" class="actionIcon"/>
                  <Title text="Vendor Onboarding" class="actionTitle"/>
                  <Text text="Capture vendor details and calculate compliance score instantly." class="actionDesc"/>
                  <Button text="Start Registration" type="Emphasized" press="onOpenOnboard" class="fullBtn"/>
                </VBox>

                <VBox class="actionCard">
                  <Text text="🤖" class="actionIcon"/>
                  <Title text="AI Assistant" class="actionTitle"/>
                  <Text text="Ask vendor-related queries with text or voice assistance." class="actionDesc"/>
                  <Button text="Open AI Assistant" press="onOpenAI" class="fullBtn"/>
                </VBox>

                <VBox class="actionCard">
                  <Text text="📡" class="actionIcon"/>
                  <Title text="Vendor Master Data" class="actionTitle"/>
                  <Text text="View mapped vendor data from SAP OData service." class="actionDesc"/>
                  <Button text="View Vendor List" press="onLoadVendors" class="fullBtn"/>
                </VBox>

              </VBox>
            </HBox>

          </VBox>
        </VBox>
      </content>
    </Page>

    <!-- VENDOR REGISTRATION PAGE -->
    <Page id="onboardPage" title="Vendor Registration" showNavButton="true" navButtonPress="onBack">
      <content>
        <VBox class="shellBg">
          <HBox class="formLayout">

            <VBox class="leftInfoCard">
              <Text text="Step 01 • Smart Onboarding" class="stepPill"/>

              <Title text="Vendor Compliance Check" class="pageTitle"/>

              <Text
                text="This module calculates a vendor onboarding score using GST, PAN, and Email validation."
                class="pageSub"/>

              <VBox class="featureLine">
                <Text text="✅ GST Number Validation" class="actionTitle"/>
                <Text text="Adds 40 score points when GST number is available." class="actionDesc"/>
              </VBox>

              <VBox class="featureLine">
                <Text text="✅ PAN Number Check" class="actionTitle"/>
                <Text text="Adds 30 score points when PAN number is provided." class="actionDesc"/>
              </VBox>

              <VBox class="featureLine">
                <Text text="✅ Email Verification" class="actionTitle"/>
                <Text text="Adds 30 score points when email format is valid." class="actionDesc"/>
              </VBox>

            </VBox>

            <VBox class="rightFormCard">
              <Text text="Vendor Details" class="badge"/>

              <Title text="Create Vendor Profile" class="pageTitle"/>

              <Text
                text="Fill vendor master details before submitting for onboarding score."
                class="pageSub"/>

              <Input id="name" placeholder="Vendor Name" class="formInput"/>
              <Input id="email" placeholder="Email Address" class="formInput"/>
              <Input id="phone" placeholder="Phone Number" class="formInput"/>
              <Input id="gst" placeholder="GST Number" class="formInput"/>
              <Input id="pan" placeholder="PAN Number" class="formInput"/>
              <Input id="company" placeholder="Company Code" class="formInput"/>
              <Input id="address" placeholder="Address" class="formInput"/>

              <Button
                text="Register Vendor"
                type="Emphasized"
                press="onRegister"
                class="fullBtn"/>
            </VBox>

          </HBox>
        </VBox>
      </content>
    </Page>

    <!-- AI PAGE -->
    <Page id="aiPage" title="AI Assistant" showNavButton="true" navButtonPress="onBack">
      <content>
        <VBox class="shellBg">
          <VBox class="aiChatBox">

            <Text text="AI Vendor Assistant" class="badge"/>

            <Title text="Ask Smarter Vendor Questions" class="pageTitle"/>

            <Text
              text="Use text or voice to ask about GST, PAN, onboarding status, approval process, or SAP OData."
              class="pageSub"/>

            <HBox class="aiSuggestionGrid">
              <VBox class="aiSuggestion">
                <Text text="💡 Documents" class="actionTitle"/>
                <Text text="What documents are required for vendor onboarding?" class="actionDesc"/>
              </VBox>

              <VBox class="aiSuggestion">
                <Text text="🧾 GST / PAN" class="actionTitle"/>
                <Text text="How is GST and PAN validated?" class="actionDesc"/>
              </VBox>

              <VBox class="aiSuggestion">
                <Text text="📡 SAP OData" class="actionTitle"/>
                <Text text="How is vendor data fetched from SAP?" class="actionDesc"/>
              </VBox>
            </HBox>

            <Input id="aiInput" placeholder="Type your question here..." class="formInput"/>

            <HBox class="actionRow">
              <Button text="🎤 Voice Input" press="onSpeak"/>
              <Button text="Ask AI" type="Emphasized" press="onAsk"/>
            </HBox>

          </VBox>
        </VBox>
      </content>
    </Page>

    <!-- VENDOR LIST -->
    <Page id="listPage" title="Vendor List" showNavButton="true" navButtonPress="onBack">
      <content>
        <VBox class="shellBg">
          <VBox class="vendorListWrap">

            <Text text="SAP OData View" class="badge"/>

            <Title text="Vendor Master Records" class="pageTitle"/>

            <Text
              text="Mapped vendor master data from SAP OData service."
              class="pageSub"/>

            <List id="vendorList" headerText="Vendor Master Records" class="vendorPremiumList"/>

          </VBox>
        </VBox>
      </content>
    </Page>

  </App>

</mvc:View>
